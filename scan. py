import requests
from bs4 import BeautifulSoup
import socket
import datetime
import ipapi
from urllib.parse import urlparse

def tambah_skema(url):
    if not url.startswith('http'):
        url = 'https://' + url
    return url

def scan_web(url, output_file="hasil_scan.txt"):
    url = tambah_skema(url)
    
    with open(output_file, 'w', encoding='utf-8') as f:
        def tulis(teks):
            print(teks)  # tetep tampil di terminal
            f.write(teks + '\n')  # + simpen ke file

        tulis(f"=== HASIL SCAN WEB ===")
        tulis(f"Waktu: {datetime.datetime.now()}")
        tulis(f"URL: {url}")
        tulis("="*40)

        try:
            # 1. Ambil domain + IP
            domain = urlparse(url).netloc
            ip = socket.gethostbyname(domain)
            tulis(f"IP: {ip}")

            # 2. ISP
            data_ip = ipapi.location(ip=ip)
            isp = data_ip.get('org', 'Unknown')
            country = data_ip.get('country_name', 'Unknown')
            tulis(f"ISP: {isp}")
            tulis(f"Negara: {country}")

            # 3. Request hemat RAM
            with requests.get(url, timeout=15, stream=True, verify=False) as r:
                tulis(f"Status: {r.status_code}")
                
                # Header
                tulis("\n[HEADER]")
                server = r.headers.get('Server', 'Not detected')
                tulis(f"Server: {server}")
                
                if 'cloudflare' in str(r.headers).lower():
                    tulis("Cloudflare: Protected")
                else:
                    tulis("Cloudflare: Unprotected")

                # 4. Baca HTML dikit aja, max 500KB
                content = b""
                for chunk in r.iter_content(chunk_size=8192):
                    content += chunk
                    if len(content) > 500000:
                        break

                soup = BeautifulSoup(content, 'lxml') # lxml lebih hemat RAM

                # 5. Title
                title = soup.title.string.strip() if soup.title else "No title"
                tulis(f"\n[HTML]\nTitle: {title}")

                # 6. Meta tag, batasi 20 aja
                tulis("\n[META TAG]")
                count = 0
                for meta in soup.find_all('meta'):
                    if count >= 20: break
                    name = meta.get('name') or meta.get('property')
                    content = meta.get('content')
                    if name and content:
                        tulis(f"{name}: {content[:150]}") # potong 150 char
                        count += 1

            tulis("\n[SELESAI] Hasil lengkap ada di: " + output_file)

        except Exception as e:
            tulis(f"Error: {e}")

if __name__ == "__main__":
    url = input("TARGET URL: ").strip()
    scan_web(url)
